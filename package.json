{
	"name": "safi-site-audit",
	"version": "0.1.0",
	"description": "Obsidian plugin that runs website audits and saves them as Markdown notes.",
	"type": "module",
	"scripts": {
		"build:css": "tailwindcss -i src/app.css -o styles.css",
		"build:js": "node esbuild.config.mjs production",
		"build": "npm run build:css && npm run build:js",
		"dev:css": "tailwindcss -i src/app.css -o styles.css --watch",
		"dev:js": "node esbuild.config.mjs",
		"test": "node --test --import tsx \"test/*.test.ts\"",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"safi-studio-scanner": "github:Abdulkader-Safi/Safi-Studio-Scanner",
		"tailwind-merge": "^3.0.0"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@tailwindcss/cli": "^4.0.0",
		"@types/node": "^22.0.0",
		"bits-ui": "^2.18.1",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"esbuild-svelte": "^0.9.0",
		"obsidian": "latest",
		"svelte": "^5.0.0",
		"svelte-preprocess": "^6.0.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.8.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0"
	}
}
