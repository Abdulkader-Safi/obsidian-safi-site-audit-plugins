{
	"name": "safi-site-audit",
	"version": "0.1.0",
	"description": "Obsidian plugin that runs website audits and saves them as Markdown notes.",
	"type": "module",
	"scripts": {
		"build": "node esbuild.config.mjs production",
		"dev": "node esbuild.config.mjs",
		"test": "node --test --import tsx \"test/*.test.ts\"",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"dependencies": {
		"safi-studio-scanner": "github:Abdulkader-Safi/Safi-Studio-Scanner"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.24.0",
		"esbuild-svelte": "^0.9.0",
		"obsidian": "latest",
		"svelte": "^5.0.0",
		"svelte-preprocess": "^6.0.0",
		"tslib": "^2.8.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0"
	}
}
